  "cases": [
    {
      "case_id": "reactor_happy_path_committed",
      "category": "happy_path",
      "description": "Reactor request commits successfully.",
      "expected": {
        "http_status": 200,
        "status": "COMMITTED",
        "must_include_stages": [
          "RECEIVED",
          "SCHEMA_VALIDATED",
          "INTEGRITY_PASSED",
          "SAFETY_PASSED",
          "PREPARE_LOCK_GRANTED",
          "REVERIFY_PASSED",
          "COMMIT_ACK"
        ],
        "must_call_paths": [
          "/validate",
          "/prepare",
          "/commit",
          "/events/append"
        ],
        "response_has_evidence_ref": true,
        "verify_evidence_chain": true
      }
    },
    {
      "case_id": "robot_happy_path_committed",
      "category": "happy_path",
