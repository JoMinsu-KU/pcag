    {
      "case_id": "missing_sensor_reliability_index_422",
      "category": "schema",
      "description": "Missing sensor_reliability_index should fail schema validation.",
      "proof": {
        "remove_fields": [
          "sensor_reliability_index"
        ]
      },
      "expected": {
        "http_status": 422,
        "status": null,
        "response_has_evidence_ref": false,
        "evidence_count_exact": 0,
        "must_not_call_paths": [
          "/events/append",
          "/prepare",
          "/commit"
        ]
      }
    },
