{
  "meta": {
    "name": "live-gateway-e2e-dataset",
    "version": "1.0",
    "description": "Single-entry live E2E dataset for the running PCAG services."
  },
  "defaults": {
    "asset_id": "reactor_01",
    "headers": {
      "X-API-Key": "pcag-agent-key-001"
    },
    "proof": {
      "schema_version": "1.0",
      "policy_version_mode": "active",
      "timestamp_offset_ms": 0,
      "sensor_hash_mode": "latest",
      "sensor_snapshot_mode": "none",
      "sensor_reliability_index": 0.95,
      "action_sequence_ref": "reactor_heat_60",
      "safety_verification_summary": {
        "checks": [],
        "assumptions": [],
        "warnings": []
      }
    },
    "expected": {
      "http_status": 200
    }
  },
  "libraries": {
    "action_sequences": {
      "reactor_heat_60": [
        {
          "action_type": "set_heater_output",
          "params": {
            "value": 60
          }
        }
      ],
      "reactor_heat_100": [
        {
          "action_type": "set_heater_output",
          "params": {
            "value": 100
          }
        }
      ],
      "agv_move_safe": [
        {
          "action_type": "move_to",
          "params": {
            "agv_id": "agv_01",
            "target_x": 5,
            "target_y": 2
          }
        }
      ],
      "agv_move_unsafe": [
        {
          "action_type": "move_to",
          "params": {
            "agv_id": "agv_01",
            "target_x": 50,
            "target_y": 20
          }
        }
      ],
      "robot_joint_out_of_range": [
        {
          "action_type": "move_joint",
          "params": {
            "target_positions": [
              0.0,
              2.5,
              0.0,
              -1.5,
              0.0,
              1.2,
              0.785,
              0.02,
              0.02
            ],
            "joint_0": 0.0,
            "joint_1": 2.5,
            "joint_2": 0.0,
            "joint_3": -1.5,
            "joint_4": 0.0,
            "joint_5": 1.2,
            "joint_6": 0.785,
            "finger_joint_0": 0.02,
            "finger_joint_1": 0.02,
            "joint_0_velocity": 0.5,
            "joint_1_velocity": 0.5,
            "joint_2_velocity": 0.5,
            "joint_3_velocity": 0.5,
            "joint_4_velocity": 0.5,
            "joint_5_velocity": 0.5,
            "joint_6_velocity": 0.5,
            "finger_joint_0_velocity": 0.1,
            "finger_joint_1_velocity": 0.1,
            "joint_0_effort": 10.0,
            "joint_1_effort": 10.0,
            "joint_2_effort": 10.0,
            "joint_3_effort": 10.0,
            "joint_4_effort": 5.0,
            "joint_5_effort": 5.0,
            "joint_6_effort": 5.0,
            "finger_joint_0_force": 10.0,
            "finger_joint_1_force": 10.0
          }
        }
      ]
    },
    "sensor_snapshots": {
      "reactor_divergence_far": {
        "temperature": 20.0,
        "pressure": 0.0,
        "heater_output": 0.0,
        "cooling_valve": 0.0,
        "reactor_status": 0.0
      }
    }
  },
  "cases": [
    {
      "case_id": "reactor_safe_commit",
      "description": "Reactor command should commit and produce a full evidence chain.",
      "expected": {
        "http_status": 200,
        "status": "COMMITTED",
        "response_has_evidence_ref": true,
        "evidence_required": true,
        "evidence_chain_valid": true,
        "evidence_stages_exact": [
          "RECEIVED",
          "SCHEMA_VALIDATED",
          "INTEGRITY_PASSED",
          "SAFETY_PASSED",
          "PREPARE_LOCK_GRANTED",
          "REVERIFY_PASSED",
          "COMMIT_ACK"
        ]
      }
    },
    {
      "case_id": "agv_safe_commit",
      "description": "AGV command should commit and produce a full evidence chain.",
      "asset_id": "agv_01",
      "proof": {
        "action_sequence_ref": "agv_move_safe"
      },
      "expected": {
        "http_status": 200,
        "status": "COMMITTED",
        "response_has_evidence_ref": true,
        "evidence_required": true,
        "evidence_chain_valid": true,
        "evidence_stages_exact": [
          "RECEIVED",
          "SCHEMA_VALIDATED",
          "INTEGRITY_PASSED",
          "SAFETY_PASSED",
          "PREPARE_LOCK_GRANTED",
          "REVERIFY_PASSED",
          "COMMIT_ACK"
        ]
      }
    },
    {
      "case_id": "reactor_unsafe_high_heater",
      "description": "Unsafe reactor heater command should stop at the safety stage.",
      "proof": {
        "action_sequence_ref": "reactor_heat_100"
      },
      "expected": {
        "http_status": 200,
        "status": "UNSAFE",
        "reason_code": "SAFETY_UNSAFE",
        "response_has_evidence_ref": false,
        "alternative_actions_min_count": 2,
        "evidence_required": true,
        "evidence_chain_valid": true,
        "evidence_stages_exact": [
          "RECEIVED",
          "SCHEMA_VALIDATED",
          "INTEGRITY_PASSED",
          "SAFETY_UNSAFE"
        ]
      }
    },
    {
      "case_id": "agv_unsafe_out_of_bounds",
      "description": "Out-of-bounds AGV move should stop at the safety stage.",
      "asset_id": "agv_01",
      "proof": {
        "action_sequence_ref": "agv_move_unsafe"
      },
      "expected": {
        "http_status": 200,
        "status": "UNSAFE",
        "reason_code": "SAFETY_UNSAFE",
        "response_has_evidence_ref": false,
        "alternative_actions_min_count": 1,
        "evidence_required": true,
        "evidence_chain_valid": true,
        "evidence_stages_exact": [
          "RECEIVED",
          "SCHEMA_VALIDATED",
          "INTEGRITY_PASSED",
          "SAFETY_UNSAFE"
        ]
      }
    },
    {
      "case_id": "robot_unsafe_joint_limit",
      "description": "Robot joint limit violation should stop at the safety stage.",
      "asset_id": "robot_arm_01",
      "proof": {
        "action_sequence_ref": "robot_joint_out_of_range"
      },
      "expected": {
        "http_status": 200,
        "status": "UNSAFE",
        "reason_code": "SAFETY_UNSAFE",
        "response_has_evidence_ref": false,
        "alternative_actions_min_count": 1,
        "evidence_required": true,
        "evidence_chain_valid": true,
        "evidence_stages_exact": [
          "RECEIVED",
          "SCHEMA_VALIDATED",
          "INTEGRITY_PASSED",
          "SAFETY_UNSAFE"
        ]
      }
    },
    {
      "case_id": "policy_version_mismatch_rejected",
      "description": "Explicit wrong policy version should be rejected by integrity.",
      "proof": {
        "policy_version_mode": "explicit",
        "policy_version_id": "v-WRONG-VERSION"
      },
      "expected": {
        "http_status": 200,
        "status": "REJECTED",
        "reason_code": "INTEGRITY_POLICY_MISMATCH",
        "response_has_evidence_ref": false,
        "evidence_required": true,
        "evidence_chain_valid": true,
        "evidence_stages_exact": [
          "RECEIVED",
          "SCHEMA_VALIDATED",
          "INTEGRITY_REJECTED"
        ]
      }
    },
    {
      "case_id": "timestamp_expired_rejected",
      "description": "Old timestamp should be rejected by integrity.",
      "proof": {
        "timestamp_offset_ms": -10000
      },
      "expected": {
        "http_status": 200,
        "status": "REJECTED",
        "reason_code": "INTEGRITY_TIMESTAMP_EXPIRED",
        "response_has_evidence_ref": false,
        "evidence_required": true,
        "evidence_chain_valid": true,
        "evidence_stages_exact": [
          "RECEIVED",
          "SCHEMA_VALIDATED",
          "INTEGRITY_REJECTED"
        ]
      }
    },
    {
      "case_id": "future_timestamp_rejected",
      "description": "Future timestamp beyond tolerance should be rejected by integrity.",
      "proof": {
        "timestamp_offset_ms": 12000
      },
      "expected": {
        "http_status": 200,
        "status": "REJECTED",
        "reason_code": "INTEGRITY_TIMESTAMP_FUTURE",
        "response_has_evidence_ref": false,
        "evidence_required": true,
        "evidence_chain_valid": true,
        "evidence_stages_exact": [
          "RECEIVED",
          "SCHEMA_VALIDATED",
          "INTEGRITY_REJECTED"
        ]
      }
    },
    {
      "case_id": "sensor_divergence_rejected",
      "description": "Large proof snapshot divergence should be rejected by integrity.",
      "proof": {
        "timestamp_offset_ms": 3000,
        "sensor_snapshot_mode": "override",
        "sensor_snapshot_ref": "reactor_divergence_far",
        "action_sequence_ref": "reactor_heat_60"
      },
      "expected": {
        "http_status": 200,
        "status": "REJECTED",
        "reason_code": "INTEGRITY_SENSOR_DIVERGENCE",
        "response_has_evidence_ref": false,
        "evidence_required": true,
        "evidence_chain_valid": true,
        "evidence_stages_exact": [
          "RECEIVED",
          "SCHEMA_VALIDATED",
          "INTEGRITY_REJECTED"
        ]
      }
    },
    {
      "case_id": "missing_sensor_reliability_index_422",
      "description": "Missing sensor_reliability_index should fail request validation.",
      "proof": {
        "remove_fields": [
          "sensor_reliability_index"
        ]
      },
      "expected": {
        "http_status": 422,
        "status": null,
        "response_has_evidence_ref": false
      }
    },
    {
      "case_id": "invalid_hash_pattern_422",
      "description": "Invalid sensor hash format should fail request validation.",
      "proof": {
        "sensor_hash_mode": "explicit",
        "sensor_snapshot_hash": "not-a-sha256-hash"
      },
      "expected": {
        "http_status": 422,
        "status": null,
        "response_has_evidence_ref": false
      }
    },
    {
      "case_id": "missing_policy_version_id_422",
      "description": "Missing policy_version_id should fail request validation.",
      "proof": {
        "remove_fields": [
          "policy_version_id"
        ]
      },
      "expected": {
        "http_status": 422,
        "status": null,
        "response_has_evidence_ref": false
      }
    },
    {
      "case_id": "unknown_asset_sensor_error",
      "description": "Unknown asset should return a sensor gateway error in live mode.",
      "asset_id": "unknown_asset_01",
      "proof": {
        "sensor_hash_mode": "explicit",
        "sensor_snapshot_hash": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
      },
      "expected": {
        "http_status": 200,
        "status": "ERROR",
        "reason_code": "SENSOR_GATEWAY_ERROR",
        "response_has_evidence_ref": false
      }
    },
    {
      "case_id": "invalid_api_key_401",
      "description": "Invalid API key should be rejected before the pipeline starts.",
      "headers": {
        "X-API-Key": "wrong-key"
      },
      "expected": {
        "http_status": 401,
        "status": null,
        "response_has_evidence_ref": false
      }
    }
  ]
}
